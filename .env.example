# Copy this file to `.env` for Docker Compose or export the same variables in your shell.

PROXYDECK_SECURITY_ENCRYPTION_KEY=change-this-with-a-strong-random-secret
PROXYDECK_ADMIN_USERNAME=admin
PROXYDECK_ADMIN_PASSWORD=change-this-before-first-run

# Optional overrides
# PROXYDECK_SQLITE_PATH=/app/data/app.db
# PROXYDECK_REDIS_ADDR=redis:6379
